## Account Registry

```python
from desktop_automation_agent import AccountRecord, AccountRegistry

registry = AccountRegistry(storage_path="data/accounts.json")

registry.upsert_account(
    AccountRecord(
        name="primary-workspace",
        credential_reference="vault://accounts/workspace-primary",
        account_type="workspace",
        application="https://example.com",
        health_score=0.97,
    )
)

registry.set_account_active("primary-workspace", True)
registry.update_last_used("primary-workspace")
registry.log_account_usage("primary-workspace", "login", "Used for dashboard automation")
accounts = registry.list_accounts(active_only=True)
```

## Credential Vault

```python
from datetime import datetime, timedelta, timezone

from desktop_automation_agent import CredentialKind, CredentialVault

vault = CredentialVault(storage_path="data/credentials.json")

vault.store_credential(
    account_identifier="primary-workspace",
    kind=CredentialKind.TOKEN,
    value="token-value",
    expires_at=datetime.now(timezone.utc) + timedelta(days=7),
)

token = vault.retrieve_credential("primary-workspace", CredentialKind.TOKEN)
history = vault.get_access_log("primary-workspace")
```

## Browser Profile Switching

```python
from desktop_automation_agent import BrowserProfileSwitcher, SubprocessBrowserLauncher

switcher = BrowserProfileSwitcher(
    storage_path="data/browser_profiles.json",
    launcher=SubprocessBrowserLauncher(),
    account_verifier=lambda account_name, profile_directory: True,
)

switcher.create_profile(
    account_name="primary-workspace",
    profile_directory="profiles/primary-workspace",
    browser_executable="C:/Program Files/Google/Chrome/Application/chrome.exe",
    application="https://example.com",
)

switcher.launch_profile("primary-workspace")
switcher.switch_profile("primary-workspace")
```

## Session State Tracking

```python
from desktop_automation_agent import (
    ScreenCheckType,
    ScreenVerificationCheck,
    SessionStateTracker,
)

tracker = SessionStateTracker(
    storage_path="data/session_state.json",
    verifier=verifier,
    reauthenticate_callback=lambda: True,
)

result = tracker.validate_session_before_high_risk_operation(
    post_login_checks=[
        ScreenVerificationCheck(
            check_id="home",
            check_type=ScreenCheckType.TEXT_PRESENT,
            target_text="Dashboard",
        )
    ],
    login_page_checks=[
        ScreenVerificationCheck(
            check_id="login",
            check_type=ScreenCheckType.TEXT_PRESENT,
            target_text="Sign in",
        )
    ],
)
```

## Account Rotation Orchestration

```python
from datetime import timedelta

from desktop_automation_agent import (
    AccountExecutionMode,
    AccountRotationOrchestrator,
    RotationTask,
)

orchestrator = AccountRotationOrchestrator(
    storage_path="data/account_rotation.json",
    account_registry=registry,
    task_executor=lambda task, account_name: True,
)

result = orchestrator.execute(
    [
        RotationTask(task_id="t1", required_account="primary-workspace"),
        RotationTask(task_id="t2", required_account="backup-workspace"),
        RotationTask(task_id="t3", required_account="primary-workspace"),
    ],
    mode=AccountExecutionMode.SEQUENTIAL,
    minimum_reuse_interval=timedelta(minutes=5),
)
```


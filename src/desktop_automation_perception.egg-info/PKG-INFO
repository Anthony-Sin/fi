## Target Application Prompt Injection

```python
from desktop_automation_agent import (
    LineEndingStyle,
    PromptInjectionMethod,
    PromptInjectionTarget,
    TargetApplicationPromptInjector,
)

injector = TargetApplicationPromptInjector(
    input_runner=input_simulator,
    clipboard_manager=clipboard_manager,
    accessibility_reader=accessibility_reader,
    ocr_extractor=ocr_extractor,
    window_manager=window_manager,
)

result = injector.inject_prompt(
    prompt="Line one\nLine two",
    target=PromptInjectionTarget(
        window_title="Prompt App",
        element_name="Prompt",
        element_role="edit",
    ),
    method=PromptInjectionMethod.CLIPBOARD,
    line_endings=LineEndingStyle.LF,
)
```

## AI Interface Navigation

```python
from desktop_automation_agent import (
    AIInterfaceConfiguration,
    AIInterfaceElementSelector,
    AIInterfaceNavigator,
    AIInterfaceSubmitMode,
    PromptInjectionMethod,
)

navigator = AIInterfaceNavigator(
    prompt_injector=injector,
    input_runner=input_simulator,
    screenshot_backend=screenshot_backend,
    accessibility_reader=accessibility_reader,
    ocr_extractor=ocr_extractor,
    template_matcher=matcher,
    window_manager=window_manager,
)

result = navigator.navigate(
    prompt="Summarize the latest deployment logs.",
    interface=AIInterfaceConfiguration(
        interface_name="chatgpt",
        input_selector=AIInterfaceElementSelector(
            name="Message",
            role="edit",
            window_title="ChatGPT",
            process_name="chrome.exe",
        ),
        submit_mode=AIInterfaceSubmitMode.AUTO,
        submit_button_selector=AIInterfaceElementSelector(name="Send", role="button"),
        response_selector=AIInterfaceElementSelector(name="Conversation", role="document"),
        streaming_indicator_selectors=[
            AIInterfaceElementSelector(name="Stop generating", role="button")
        ],
        error_dialog_selectors=[
            AIInterfaceElementSelector(name="Something went wrong", role="dialog")
        ],
        session_timeout_selectors=[
            AIInterfaceElementSelector(name="Sign in", role="dialog")
        ],
    ),
    injection_method=PromptInjectionMethod.CLIPBOARD,
)
```

## Multi-Step Prompt Pipeline Runner

```python
from desktop_automation_agent import (
    PipelineResponseAction,
    PromptPipelineRunner,
    PromptPipelineStep,
)

runner = PromptPipelineRunner(
    template_manager=prompt_template_manager,
    navigator=navigator,
    review_callback=lambda request: review_result,
)

result = runner.run(
    [
        PromptPipelineStep(
            step_id="research",
            interface=chatgpt_interface,
            template_name="collect-facts",
            template_variables={"topic": "robotics"},
            expected_response_pattern=r".+",
            output_variable_name="research_notes",
        ),
        PromptPipelineStep(
            step_id="summary",
            interface=claude_interface,
            template_name="write-summary",
            template_variables={"audience": "executive"},
            response_action=PipelineResponseAction.STORE_AS,
            output_variable_name="final_summary",
            allow_human_review=True,
        ),
    ],
    initial_variables={"operator": "primary"},
)
```

## Response Extractor And Parser

```python
from desktop_automation_agent import (
    ResponseExtractionConfiguration,
    ResponseExtractorParser,
    ResponseProcessingMode,
    ResponseValidationMode,
)

extractor = ResponseExtractorParser(
    screenshot_backend=screenshot_backend,
    accessibility_reader=accessibility_reader,
    ocr_extractor=ocr_extractor,
    template_matcher=matcher,
    navigator=navigator,
)

result = extractor.extract_response(
    configuration=ResponseExtractionConfiguration(
        interface_name="chatgpt",
        response_selector=AIInterfaceElementSelector(name="Conversation", role="document"),
        processing_modes=(
            ResponseProcessingMode.STRIP_FORMATTING,
            ResponseProcessingMode.EXTRACT_JSON_BLOCK,
        ),
        validation_mode=ResponseValidationMode.JSON_SCHEMA_LITE,
        expected_schema={"status": "string", "summary": "string"},
        retry_on_validation_failure=True,
        max_retry_attempts=1,
    ),
    interface=chatgpt_interface,
    prompt="Return deployment status as JSON.",
)
```

## Application Launcher

```python
from desktop_automation_agent import (
    AIInterfaceElementSelector,
    ApplicationLaunchMode,
    ApplicationLaunchRequest,
    ApplicationLauncher,
    ApplicationRegistry,
    ApplicationStartupSignature,
    KnownApplicationRecord,
    SubprocessApplicationLauncherBackend,
)

registry = ApplicationRegistry(storage_path="data/applications.json")
registry.upsert_application(
    KnownApplicationRecord(
        name="chatgpt-desktop",
        launch_mode=ApplicationLaunchMode.EXECUTABLE,
        executable_path="C:/Program Files/ChatGPT/ChatGPT.exe",
        default_arguments=("--profile", "work"),
        startup_signature=ApplicationStartupSignature(
            window_title="ChatGPT",
            process_name="ChatGPT.exe",
            element_selector=AIInterfaceElementSelector(name="Message", role="edit"),
        ),
    )
)

launcher = ApplicationLauncher(
    registry=registry,
    backend=SubprocessApplicationLauncherBackend(),
    window_manager=window_manager,
    accessibility_reader=accessibility_reader,
    ocr_extractor=ocr_extractor,
    template_matcher=matcher,
    screenshot_backend=screenshot_backend,
)

result = launcher.launch(
    ApplicationLaunchRequest(
        application_name="chatgpt-desktop",
        launch_mode=ApplicationLaunchMode.EXECUTABLE,
        arguments=("--workspace", "ops"),
        timeout_seconds=20.0,
        retry_attempts=2,
    )
)
```

## Navigation Step Sequencer

```python
from desktop_automation_agent import (
    NavigationSequenceMode,
    NavigationStep,
    NavigationStepActionType,
    NavigationStepSequencer,
    ScreenCheckType,
    ScreenVerificationCheck,
)

sequencer = NavigationStepSequencer(
    input_runner=input_simulator,
    verifier=screen_verifier,
    launcher=application_launcher,
)

result = sequencer.run(
    [
        NavigationStep(
            step_id="open-app",
            action_type=NavigationStepActionType.NAVIGATE,
            target_description="Open chat workspace",
            input_data={"launch_request": launch_request},
            expected_post_action_state=[
                ScreenVerificationCheck(
                    check_id="chat-ready",
                    check_type=ScreenCheckType.TEXT_PRESENT,
                    target_text="Message",
                )
            ],
        ),
        NavigationStep(
            step_id="click-input",
            action_type=NavigationStepActionType.CLICK,
            target_description="Prompt input field",
            input_data={"element_bounds": (900, 720, 1500, 820)},
        ),
        NavigationStep(
            step_id="wait-stream",
            action_type=NavigationStepActionType.WAIT,
            target_description="Wait for UI settle",
            input_data={"seconds": 1.0},
            optional=True,
        ),
    ],
    mode=NavigationSequenceMode.STRICT,
)
```

## Menu And Dialog Navigator

```python
from desktop_automation_agent import (
    AIInterfaceElementSelector,
    DialogHandlingRequest,
    DialogResponse,
    MenuDialogNavigator,
    MenuNavigationRequest,
    UnexpectedDialogPolicy,
)

navigator = MenuDialogNavigator(
    input_runner=input_simulator,
    screenshot_backend=screenshot_backend,
    accessibility_reader=accessibility_reader,
    ocr_extractor=ocr_extractor,
    template_matcher=matcher,
    window_manager=window_manager,
)

menu_result = navigator.select_menu_item(
    MenuNavigationRequest(
        menu_label="File",
        menu_selector=AIInterfaceElementSelector(name="File", role="menu item"),
        custom_menu_selector=AIInterfaceElementSelector(name="File", role="button"),
    )
)

dialog_result = navigator.handle_dialog(
    DialogHandlingRequest(
        dialog_selector=AIInterfaceElementSelector(name="Confirm Save", role="dialog"),
        response=DialogResponse.ACCEPT,
    )
)

unexpected = navigator.handle_unexpected_dialogs(
    dialog_selectors=[AIInterfaceElementSelector(name="Unsaved Changes", role="dialog")],
    policy=UnexpectedDialogPolicy(default_response=DialogResponse.CANCEL),
)
```

## Form Automation Module

```python
from desktop_automation_agent import (
    FormAutomationModule,
    FormFieldType,
    FormFieldValue,
)

form = FormAutomationModule(
    input_runner=input_simulator,
    accessibility_reader=accessibility_reader,
    ocr_extractor=ocr_extractor,
    window_manager=window_manager,
)

result = form.fill_form(
    [
        FormFieldValue(label="First Name", value="Avery", field_type=FormFieldType.TEXT),
        FormFieldValue(label="Country", value="Canada", field_type=FormFieldType.DROPDOWN),
        FormFieldValue(label="Subscribe", value=True, field_type=FormFieldType.CHECKBOX),
        FormFieldValue(label="Start Date", value="2026-04-08", field_type=FormFieldType.DATE),
    ]
)
```

## Multi-Application Workflow Coordinator

```python
from desktop_automation_agent import (
    MultiApplicationWorkflowCoordinator,
    WorkflowDataExchangeMode,
    WorkflowExchangeRequest,
    WorkflowStep,
)

coordinator = MultiApplicationWorkflowCoordinator(
    launcher=application_launcher,
    window_manager=window_manager,
    clipboard_manager=clipboard_manager,
    dry_run=False,
)

result = coordinator.run(
    [
        WorkflowStep(
            step_id="draft",
            application_name="Writer",
            launch_request=writer_launch_request,
            required_window_title="Writer",
            outgoing_exchange=WorkflowExchangeRequest(
                mode=WorkflowDataExchangeMode.CLIPBOARD,
                data_key="draft_text",
                value="Quarterly update",
            ),
        ),
        WorkflowStep(
            step_id="paste",
            application_name="Sheets",
            launch_request=sheets_launch_request,
            required_window_title="Sheets",
            incoming_exchange=WorkflowExchangeRequest(
                mode=WorkflowDataExchangeMode.CLIPBOARD,
                data_key="draft_text",
            ),
        ),
    ]
)
```

## Exponential Backoff Retry Engine

```python
from desktop_automation_agent import (
    ExponentialBackoffRetryEngine,
    RetryConfiguration,
    RetryDisposition,
    RetryExceptionRule,
    RetryExhaustedError,
)

engine = ExponentialBackoffRetryEngine()

try:
    result = engine.run(
        fragile_action,
        configuration=RetryConfiguration(
            max_retry_count=4,
            initial_delay_seconds=0.5,
            backoff_multiplier=2.0,
            max_delay_seconds=8.0,
            exception_rules=[
                RetryExceptionRule("TimeoutError", RetryDisposition.RETRY),
                RetryExceptionRule("ValueError", RetryDisposition.FAIL),
            ],
        ),
    )
except RetryExhaustedError as exc:
    failure = exc.failure
    print(failure.attempts, failure.final_exception_type, failure.final_exception_message)
```

## Checkpoint Manager

```python
from desktop_automation_agent import (
    CheckpointManager,
    CheckpointResumePolicy,
)

manager = CheckpointManager(storage_path="data/workflow_checkpoints.json")

manager.save_checkpoint(
    workflow_id="ops-workflow",
    step_index=3,
    workflow_context=context,
    account_context={"account": "primary"},
    collected_data=context.shared_data,
    step_outcomes=step_results,
)

restore = manager.restore_or_restart(
    workflow_id="ops-workflow",
    policy=CheckpointResumePolicy.AUTO_RESUME,
)

if restore.succeeded and restore.checkpoint is not None:
    context = restore.checkpoint.workflow_context
```

## Pre-Condition And Post-Condition Validator

```python
from desktop_automation_agent import (
    ConditionDescription,
    PrePostConditionValidator,
    RetryConfiguration,
    ScreenCheckType,
    ScreenVerificationCheck,
)

validator = PrePostConditionValidator(
    verifier=screen_verifier,
    retry_engine=retry_engine,
)

condition = ConditionDescription(
    condition_id="chat-ready",
    description="Message input must be visible",
    checks=[
        ScreenVerificationCheck(
            check_id="message",
            check_type=ScreenCheckType.TEXT_PRESENT,
            target_text="Message",
        )
    ],
)

pre = validator.validate_pre_condition(condition)
post = validator.validate_post_condition(
    condition,
    retry_configuration=RetryConfiguration(max_retry_count=2),
    escalate_on_failure=True,
)
```


from desktop_automation_agent import PerformanceMetricsCollector

metrics = PerformanceMetricsCollector(storage_path="artifacts/performance_metrics.json")

metrics.record_step_execution(
    workflow_id="workflow-123",
    step_name="submit_prompt",
    execution_time_seconds=1.4,
)
metrics.record_retry(
    workflow_id="workflow-123",
    step_name="submit_prompt",
    retry_count=1,
)
metrics.record_workflow_completion(
    workflow_id="workflow-123",
    succeeded=True,
    step_count=4,
)
metrics.record_dlq_depth(depth=2)
metrics.record_session(session_id="session-1", application_name="Chat App")

snapshot = metrics.generate_snapshot(window_seconds=3600).snapshot
endpoint_text = metrics.render_metrics_endpoint(window_seconds=3600).endpoint_payload
```


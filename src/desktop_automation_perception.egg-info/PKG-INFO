## Orchestrator Agent Core

```python
from desktop_automation_agent import OrchestratorAgentCore

agent = OrchestratorAgentCore(fallback_module="human_review")
plan = agent.create_plan(
    "Launch ChatGPT, then submit a summary prompt, then verify the response format."
)

result = agent.execute_plan(
    plan,
    executor=lambda subtask, outputs: {
        f"{subtask.subtask_id}_result": f"completed:{subtask.responsible_module}"
    },
)
```

## Specialist Agent Router

```python
from desktop_automation_agent import OrchestratorSubtask, SpecialistAgentRouter

router = SpecialistAgentRouter(
    storage_path="data/routing_decisions.json",
    escalation_target="orchestrator",
)

router.register_agent(
    agent_name="chat-agent",
    capabilities=["ai_interface_navigator", "prompt"],
    module_reference="ai_interface_navigator",
)

result = router.route_subtask(
    OrchestratorSubtask(
        subtask_id="subtask-1",
        description="Submit a prompt in ChatGPT",
        responsible_module="ai_interface_navigator",
        expected_outputs=["subtask-1_result"],
    )
)
```

## Agent Message Bus

```python
from desktop_automation_agent import AgentMessageBus

bus = AgentMessageBus(storage_path="data/agent_bus.json")

bus.subscribe(agent_id="planner", topic="workflow.status")
bus.publish(
    sender_id="orchestrator",
    topic="workflow.status",
    message_type="subtask_completed",
    payload={"subtask_id": "subtask-1"},
    correlation_id="workflow-42",
)
bus.send_direct(
    sender_id="planner",
    recipient_id="reviewer",
    message_type="review_request",
    payload={"proposal_id": "prop-1"},
    correlation_id="workflow-42",
)
```

## Shared State Manager

```python
from desktop_automation_agent import SharedStateConflictPolicy, SharedStateManager

state = SharedStateManager(
    storage_path="data/shared_state.json",
    conflict_policy=SharedStateConflictPolicy.PRIORITY_BASED,
    agent_priorities={"orchestrator": 10, "executor": 5},
)

state.define_field(
    field_name="current_application",
    field_type="string",
    initial_value="ChatGPT",
    read_agents=["orchestrator", "executor"],
    write_agents=["executor"],
)

state.write_field(agent_id="executor", field_name="current_application", value="Sheets")
snapshot = state.snapshot().snapshot
```

## Agent Handoff Protocol

```python
from desktop_automation_agent import AgentHandoffContext, AgentHandoffProtocol, AgentHandoffReason

handoff = AgentHandoffProtocol(
    storage_path="data/agent_handoffs.json",
    message_bus=bus,
)

result = handoff.create_handoff(
    sender_agent_id="planner",
    receiver_agent_id="executor",
    context=AgentHandoffContext(
        current_step="submit-prompt",
        collected_data={"prompt": "Summarize the logs"},
        plan_description="launch -> submit prompt -> validate response",
    ),
    reason=AgentHandoffReason.CAPABILITY_MISMATCH,
    special_instructions="Take over prompt submission and preserve the current variables.",
    overlap_seconds=120,
)
```
